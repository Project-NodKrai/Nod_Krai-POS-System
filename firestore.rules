rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stores
    // Fields: ownerId, name, subdomain, createdAt
    //
    // Collection: stores/{storeId}/products
    // Fields: storeId, name, category, price, cost, stock, minStock, imageUrl
    //
    // Collection: stores/{storeId}/categories
    // Fields: name
    //
    // Collection: stores/{storeId}/sales
    // Fields: storeId, items, totalAmount, paymentMethod, timestamp, staffId
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStoreOwner(storeId) {
      return isAuthenticated() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    function isNewStoreOwner() {
      return isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function isValidStore(data) {
      return data.keys().hasAll(['ownerId', 'name', 'subdomain']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.subdomain is string && data.subdomain.size() > 0 && data.subdomain.size() < 50 &&
             (!('bankName' in data) || data.bankName is string) &&
             (!('accountNumber' in data) || data.accountNumber is string) &&
             (!('accountHolder' in data) || data.accountHolder is string) &&
             (!('qrCodeUrl' in data) || data.qrCodeUrl is string) &&
             (!('allowCash' in data) || data.allowCash is bool) &&
             (!('hideOutOfStock' in data) || data.hideOutOfStock is bool) &&
             (!('lowStockThreshold' in data) || data.lowStockThreshold is number) &&
             (!('adminPin' in data) || data.adminPin is string);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['storeId', 'name', 'price', 'stock']) &&
             data.storeId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['storeId', 'items', 'totalAmount', 'paymentMethod', 'status', 'timestamp']) &&
             data.storeId is string &&
             data.items is list &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.paymentMethod in ['cash', 'card', 'transfer'] &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /stores/{storeId} {
      allow list: if isAuthenticated(); // Allow listing for subdomain uniqueness check
      allow get: if isAuthenticated(); // Allow reading store info if logged in (for POS access)
      allow create: if isAuthenticated() && isNewStoreOwner() && isValidStore(request.resource.data);
      allow update: if isStoreOwner(storeId) && isValidStore(request.resource.data);
      allow delete: if isStoreOwner(storeId);

      match /categories/{categoryId} {
        allow read: if isAuthenticated();
        allow create, update: if isStoreOwner(storeId) && isValidCategory(request.resource.data);
        allow delete: if isStoreOwner(storeId);
      }

      match /products/{productId} {
        allow read: if isAuthenticated(); // Staff/Kiosk needs to read products
        allow create, update: if isStoreOwner(storeId) && isValidProduct(request.resource.data);
        allow delete: if isStoreOwner(storeId);
      }

      match /sales/{saleId} {
        allow read: if isAuthenticated(); // Staff/Kiosk needs to read sales for status updates
        allow create: if isAuthenticated() && isValidSale(request.resource.data);
        allow update: if isAuthenticated() && (isStoreOwner(storeId) || (resource.data.status == 'pending' && (request.resource.data.status == 'completed' || request.resource.data.status == 'cancelled')));
        allow delete: if isStoreOwner(storeId);
      }
    }
  }
}
